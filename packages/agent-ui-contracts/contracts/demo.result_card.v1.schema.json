{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "demo.result_card.v1",
  "title": "Demo Result Card",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "summary"],
  "properties": {
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  }
}
