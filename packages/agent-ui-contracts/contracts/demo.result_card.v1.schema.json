{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "demo.result_card.v1",
  "title": "Demo Result Card",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "summary"],
  "properties": {
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file_id", "name"],
        "properties": {
          "file_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "mime_type": {
            "type": ["string", "null"]
          },
          "size_bytes": {
            "type": ["integer", "null"]
          }
        }
      },
      "default": []
    }
  }
}
